# Copy this file to .env and fill in real values before running docker compose.

# --- Postgres ---
POSTGRES_USER=roadway
POSTGRES_PASSWORD=roadway_dev_password
POSTGRES_DB=roadway_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full SQLAlchemy URL used by the backend (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://roadway:roadway_dev_password@postgres:5432/roadway_ai

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- LLM Provider ---
# Required for the RAG assistant, inspection report generation, design review, and executive reporting.
# Leave blank to run in "stub" mode (deterministic canned responses, no external calls).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Storage ---
STORAGE_DIR=/app/storage
CHROMA_DIR=/app/chroma_data

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
